# ============================================
# NIKENME+ 環境変数テンプレート
# ============================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# ============================================
# アプリケーション URL
# ============================================
# 本番: https://nikenme.jp
# 開発: http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://nikenme.jp
NEXT_PUBLIC_APP_URL=https://nikenme.jp

# ============================================
# Supabase
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================
# Stripe
# ============================================
# 本番: pk_live_xxx / sk_live_xxx
# テスト: pk_test_xxx / sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# Google Maps
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================
# Google Analytics
# ============================================
NEXT_PUBLIC_GA_ID=

# ============================================
# Twilio (IVR/自動音声予約)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
